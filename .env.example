# Copy to .env (gitignored) and fill in. Used by tools/watchdog.py.
# Get the token from @BotFather in Telegram; get the chat id via:
#   ./.venv/bin/python tools/watchdog.py --get-chat-id
TELEGRAM_BOT_TOKEN=123456789:ABCdef-your-bot-token-from-botfather
TELEGRAM_CHAT_ID=123456789

# Alert when any holding moves at least this percent in a day
WATCHDOG_MOVE_PCT=5

# Groq (groq.com) API key for the AI tech-scene digest — free & fast. https://console.groq.com
# (GROK_API_KEY also accepted as a fallback name.)
GROQ_API_KEY=gsk_your-free-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile
