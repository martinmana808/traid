<dict>
  <key>Label</key>
  <string>com.traid.autopilot</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/martinmana/Projects/TRaid/scripts/autopilot-run.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/martinmana/Projects/TRaid</string>
  <key>EnvironmentVariables</key>
